# RTS technology tree.
#
# Technologies consume time and physical resources.
#
# Category is intentionally broad: SCIENCE.
# Layout lanes describe the visible civilization-science tree:
# Core Sciences -> Natural Sciences -> Engineering / Medicine,
# with Social Sciences and Military Science branching from the same trunk.
#
# No technology modifies WorkerCapacity.
#
# Main dependencies connect only adjacent logical layers.
# Side technologies are optional dead ends and are not required later.


# ============================================================
# SCIENTIFIC DEVELOPMENT TREE
# ============================================================

# ----------------------------
# ENGINEERING AND INDUSTRY - LAYER 1
# ----------------------------

technology forestry
    name "Mathematics"
    description "Counting, ratios and measured work create the foundation for every later science."
    category SCIENCE
    layout_lane "Core Sciences"
    tags production
    layout_order 10
    research_time 12
    cost PAPER 20
    cost WOOD 30
    cost TOOLS 5
    modifier ProductionCycleTime multiplier 0.75 building Woodcutter
    modifier ProductionOutputAmount additive 1 multiplier 1.0 building Woodcutter resource WOOD
end

technology masonry
    name "Physics"
    description "Natural philosophy explains force, weight and materials well enough to improve construction and defense."
    category SCIENCE
    layout_lane "Core Sciences"
    tags production expansion military
    layout_order 20
    research_time 16
    cost PAPER 12
    cost STONE 30
    cost TOOLS 4
    modifier HitPoints multiplier 1.15 building Headquarters
    modifier HitPoints multiplier 1.15 building GuardTower
    modifier HitPoints multiplier 1.15 building Fortress
    modifier HitPoints multiplier 1.15 building Castle
    requires forestry
end

technology workshop_measurements
    name "Geometry and Measurement"
    description "Standard units, angles and workshop measurements make repeatable craft possible."
