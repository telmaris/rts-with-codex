    layout_order 30
    research_time 18
    cost PAPER 18
    cost TOOLS 8
    modifier ProductionCycleTime multiplier 0.92 building Smith
    modifier ProductionCycleTime multiplier 0.92 building Paperworks
end

technology cartwrighting
    name "Cartwrighting"
    description "Improved carts reduce transport delays and increase road efficiency."
