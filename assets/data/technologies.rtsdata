# RTS technology tree.
#
# Technologies consume time and physical resources.
#
# Categories:
# PRODUCTION
# WARFARE
# SOCIAL
#
# No technology modifies WorkerCapacity.
#
# Main dependencies connect only adjacent logical layers.
# Side technologies are optional dead ends and are not required later.


# ============================================================
# PRODUCTION
# ============================================================

# ----------------------------
# PRODUCTION — LAYER 1
# ----------------------------

technology forestry
    name "Swift Woodcutting"
    description "Improved axes and cutting methods increase basic wood production."
    category PRODUCTION
    layout_order 10
    research_time 12
    cost PAPER 20
    cost WOOD 30
    cost TOOLS 5
    modifier ProductionCycleTime multiplier 0.75 building Woodcutter
    modifier ProductionOutputAmount additive 1 multiplier 1.0 building Woodcutter resource WOOD
end

technology masonry
    name "Masonry"
    description "Basic stoneworking techniques improve construction quality and defensive durability."
    category PRODUCTION
    layout_order 20
    research_time 16
    cost PAPER 12
    cost STONE 30
    cost TOOLS 4
    modifier HitPoints multiplier 1.15 building Headquarters
    modifier HitPoints multiplier 1.15 building GuardTower
    modifier HitPoints multiplier 1.15 building Fortress
    modifier HitPoints multiplier 1.15 building Castle
end

technology workshop_measurements
    name "Workshop Measurements"
    description "Standardized weights and measurements improve workshop reliability."
